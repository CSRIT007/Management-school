DATABASE_URL=postgresql://postgres:postgres@localhost:5433/management_school
PORT=4000

# Bind server on all network interfaces (required for public/LAN access)
HOST=0.0.0.0

# Docker web port exposed to the internet/LAN (nginx serves app + /api proxy)
WEB_PORT=8080

# Your public URL — replace YOUR_PUBLIC_IP with your real public IP or domain
PUBLIC_URL=http://YOUR_PUBLIC_IP:8080
