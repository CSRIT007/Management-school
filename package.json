{
  "name": "management",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:public": "vite --host 0.0.0.0",
    "server": "node server/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "docker:pull": "docker pull node:22-alpine && docker pull nginx:alpine",
    "docker:build": "npm run docker:pull && docker compose build",
    "docker:up": "docker compose up -d && node scripts/print-urls.mjs",
    "docker:restart": "npm run docker:build && npm run docker:up",
    "urls": "node scripts/print-urls.mjs",
    "db:password": "node scripts/db-set-password.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "pg": "^8.22.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.13",
    "vite": "^7.1.2"
  }
}
