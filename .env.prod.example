# Copy to .env on your EC2 server before running ./scripts/deploy.sh
#   cp .env.prod.example .env
#   nano .env
#
# Then: ./scripts/deploy.sh
# deploy.sh rewrites DATABASE_URL automatically so the API can reach Postgres
# via Docker DNS host "db" (fixes ENOTFOUND / getaddrinfo DNS errors).

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=management_school

# OPTIONAL — deploy.sh overwrites this to:
#   postgresql://POSTGRES_USER:URLENCODED_PASSWORD@db:5432/POSTGRES_DB
# Do NOT use localhost or your public domain (school.csrsms.com) as the DB host.
DATABASE_URL=postgresql://postgres:change_me_to_a_strong_password@db:5432/management_school

# JWT secret for login tokens (use a long random string in production)
JWT_SECRET=change_me_to_a_long_random_secret

# Your public site URL (Cloudflare / Elastic IP / domain) — no trailing slash
PUBLIC_URL=https://school.csrsms.com

# Web port exposed on the server (80 for HTTP behind Cloudflare)
WEB_PORT=80
